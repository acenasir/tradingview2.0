# ─────────────────────────────────────────────────────────────────────────────
# OpenChart environment variables
#
# Copy this file to `.env` and fill in the keys you have. The app is fully
# functional in the DEFAULT "delayed-free" mode with just ONE data key present
# (Twelve Data recommended). All keys are read server-side by the /api proxy
# functions — secrets NEVER reach the browser bundle.
#
# For local dev run `vercel dev` (serves the Vite app + /api together).
# In production, set these in the Vercel dashboard (Project → Settings → Env).
# ─────────────────────────────────────────────────────────────────────────────

# ── Market data (pick whichever you sign up for) ────────────────────────────
# Twelve Data — global coverage + symbol search. Free tier ~800 req/day, 8 req/min.
# Sign up: https://twelvedata.com/  (Dashboard → API Keys)
TWELVEDATA_KEY=

# Finnhub — optional US real-time WebSocket (realtime mode) + company news.
# Free tier: 60 req/min. Sign up: https://finnhub.io/
FINNHUB_KEY=

# Alpha Vantage — optional last-resort delayed fallback. Free tier is very low
# (25 req/day). Sign up: https://www.alphavantage.co/support/#api-key
ALPHAVANTAGE_KEY=

# ── Paper trading + free IEX data (Alpaca "Paper Only" account) ──────────────
# Generate PAPER keys at https://alpaca.markets/ (Paper Trading → API Keys).
# $100k virtual balance. These connect ONLY to the paper host — never live money.
ALPACA_KEY_ID=
ALPACA_SECRET_KEY=

# ── Optional access guard (recommended before deploying to production) ───────
# If set, the /api proxy requires this passcode so random visitors can't place
# orders on your paper account or burn your free data quotas. Leave blank to
# disable (fine for purely local use).
APP_PASSCODE=

# ── Client-exposed, NON-SECRET values (VITE_ prefix reaches the browser) ─────
# Finnhub's WS token is client-exposed by design (low-sensitivity, rate-limited).
# Only set this if you want browser-direct Finnhub realtime streaming.
VITE_FINNHUB_TOKEN=
